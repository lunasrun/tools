{
  "name": "lunas-playground",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The Lunas playground — an in-browser editor & live preview for .lunas single-file components, built with Lunas itself.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lunasrun/tools.git"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "wasm:build": "node scripts/build-wasm.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "node --test \"test/**/*.test.mjs\""
  },
  "dependencies": {
    "lunas": "file:external/lunas/packages/lunas"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.0",
    "vite-plugin-lunas": "file:external/lunas/packages/vite-plugin-lunas"
  }
}
