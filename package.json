{
  "name": "lunas-tools",
  "version": "0.0.0",
  "private": true,
  "description": "Editor & build tooling for the Lunas web framework: type-checker (lunas-tsc), language server (lunas-ls), VS Code extension, and syntax grammar.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lunasrun/tools.git"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "wasm:build": "pnpm --filter @lunas-tools/wasm run build:wasm"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
