{
  "name": "lunas-ls",
  "version": "0.0.0",
  "description": "The Lunas language server (LSP) — diagnostics for .lunas files, for Node and the browser.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "lunas-ls": "./dist/node.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": "./dist/node.js",
    "./browser": "./dist/browser.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@lunas-tools/wasm": "workspace:*",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-languageserver-types": "^3.17.5"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^20.19.0"
  }
}
