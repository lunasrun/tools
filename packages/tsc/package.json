{
  "name": "lunas-tsc",
  "version": "0.0.0",
  "description": "CLI diagnostics / type-checker for Lunas (.lunas) files.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "lunas-tsc": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@lunas-tools/wasm": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^20.19.0"
  }
}
