html:
    <!-- a comment with a stray brace } should not break the block -->
    <div title="literal { not an interpolation }">
        <p>${"a string with a } brace inside"}</p>
        <p>${count}</p>
    </div>

script:
    // a line comment with a brace }
    /* a block comment with a brace } */
    const label = "text with { brace and } too"
    let count = 0
    function bump() {
        count = count + 1
    }
