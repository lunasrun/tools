@input label:string = "Counter"

html:
    <main class="app">
        <h1>${label}</h1>
        <p>Count: ${count}</p>
        <button @click="increment()">+1</button>
        <p :if="count == 0">Click the button to begin.</p>
        <p :elseif="count > 5">You are on a roll!</p>
        <p :else>Keep going.</p>
        <ul>
            <li :for="n of history" :key="n">Was ${n}</li>
        </ul>
    </main>

style:
    .app {
        font-family: sans-serif;
        max-width: 40rem;
        margin: 2rem auto;
    }
    button {
        margin-right: 0.5rem;
    }

script:
    let count = 0
    let history: number[] = []
    function increment() {
        history = [...history, count]
        count = count + 1
    }
