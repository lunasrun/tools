@use Counter from "./Counter.lunas"
@use Card from "./Card.lunas"

html:
    <main class="app">
        <Card tone="lead">
            <Counter :start="seed" ::value="shared" @overflow="onOverflow()"/>
        </Card>
        <input type="text" ::value="name">
        <p class="tag ${flavor}">name=${name}</p>
    </main>

script:
    let seed = 10
    let shared = 0
    let name = "ada"
    let flavor = "sweet"
    function onOverflow() {
        shared = 0
    }
